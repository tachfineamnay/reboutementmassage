GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
SITE_URL=https://domaine-final.tld
NEXT_PUBLIC_SITE_URL=https://domaine-final.tld

# Optional Go High Level settings
# vide = mock en local, live en production ; forcer mock/live si besoin
GHL_LEAD_MODE=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_SOURCE=Landing Méthode TMS
GHL_ASSIGNED_USER_ID=
GHL_DEFAULT_TAGS=landing-tms,demande-privee,source-landing-page
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
GHL_WORKFLOW_ID=

# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/tms_db

# Auth admin (générer avec: openssl rand -base64 32)
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_SECRET=

# Stockage uploads (laisser vide pour utiliser ./uploads/ en local)
# En production Coolify : /app/storage/uploads
UPLOAD_DIR=
UPLOAD_PUBLIC_PATH=/uploads
