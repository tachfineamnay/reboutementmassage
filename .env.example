GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
SITE_URL=https://domaine-final.tld
NEXT_PUBLIC_SITE_URL=https://domaine-final.tld

# Optional Go High Level settings
# vide = mock en local, live en production ; forcer mock/live si besoin
GHL_LEAD_MODE=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_SOURCE=Landing Méthode TMS
GHL_ASSIGNED_USER_ID=
GHL_DEFAULT_TAGS=source-site-premium,channel-ghl
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
GHL_WORKFLOW_ID=

# Notifications email B2B via Resend
RESEND_API_KEY=
LEAD_NOTIFICATION_FROM=Gregory Tordjman <leads@domaine-final.tld>
LEAD_NOTIFICATION_TO=
LEAD_NOTIFICATION_BCC=

# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/tms_db
# Optionnel : synchroniser le schéma au démarrage. Une erreur Prisma ne bloque
# jamais le serveur web. Laisser à 0 si la synchronisation est gérée séparément.
RUN_DB_PUSH=0

# Auth admin (générer avec: openssl rand -base64 32)
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_SECRET=

# OpenAI Article Studio (server-side only)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1
# Optional but recommended for dashboard-stored secrets.
# Generate with: openssl rand -base64 32
ADMIN_SETTINGS_ENCRYPTION_KEY=

# Stockage uploads (laisser vide pour utiliser ./uploads/ en local)
# En production Coolify : /app/storage/uploads
UPLOAD_DIR=
UPLOAD_PUBLIC_PATH=/uploads
