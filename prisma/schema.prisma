// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Méthode TMS® CMS
// Prisma 7 : pas de `url` dans datasource (géré via prisma.config.ts)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Locale {
  FR
  EN
  ES
}

enum ArticleStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum LandingSectionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadStatus {
  CAPTURED
  MOCKED
  SENT_TO_GHL
  FAILED
  ARCHIVED
}

enum TranscreationStatus {
  DRAFT
  AI_GENERATED
  REVIEWED
  PUBLISHED
  ARCHIVED
}

enum AudioProvider {
  ELEVENLABS
  OTHER
}

enum StudioStage {
  RESEARCH
  BRIEF
  OUTLINE
  DRAFT
  FACT_CHECK
  SEO
  TRANSLATION
  IMAGE
}

enum StudioRunStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum StudioArtifactStatus {
  GENERATED
  APPROVED
  REJECTED
  SUPERSEDED
}

enum StudioClaimStatus {
  VERIFIED
  NEEDS_NUANCE
  UNSUPPORTED
  HUMAN_EVIDENCE_REQUIRED
}

enum StudioSourceStatus {
  CANDIDATE
  APPROVED
  REJECTED
}

enum HumanEvidenceStatus {
  DRAFT
  VERIFIED
  REJECTED
}

enum SeoIssueSeverity {
  INFO
  WARNING
  CRITICAL
}

enum SeoSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  APPLIED
}

enum SeoEntityType {
  PERSON
  ORGANIZATION
  LOCAL_BUSINESS
}

// ── Growth CMS enums ────────────────────────────────────────────────────────

enum DestinationStatus {
  DRAFT
  READY
  LIVE
  PAUSED
  ARCHIVED
}

enum DestinationMaturity {
  TEST
  ACTIVE
  PREMIUM
  PARTNERSHIP
}

enum OfferType {
  PRIVATE_SESSION
  FOUNDER_SESSION
  HOTEL_EXPERIENCE
  HOSPITALITY_PARTNER
  WORKSHOP
  TRAINING
  RETREAT
  CORPORATE
  VIP_SIGNATURE
}

enum OfferStatus {
  DRAFT
  READY
  LIVE
  PAUSED
  ARCHIVED
}

enum LandingTemplate {
  MOBILE_WHATSAPP_FIRST
  PREMIUM_PRIVATE_SESSION
  B2B_HOSPITALITY
  FORMATION_LEADGEN
  SEO_LOCAL_SERVICE
  EVENT_WORKSHOP
}

enum LandingStatus {
  DRAFT
  READY
  LIVE
  PAUSED
  ARCHIVED
}

enum WhatsappProvider {
  WHATSAPP_APP
  GHL_WHATSAPP_PLATFORM
  META_CLOUD_API
}

enum WhatsappChannelStatus {
  NOT_CONFIGURED
  APP_ONLY
  CONNECTED_GHL
  ACTIVE
  PAUSED
  BLOCKED
}

enum TrackingProfileStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CrmRoutingStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum TestimonialStatus {
  DRAFT
  READY
  LIVE
  ARCHIVED
}

enum CampaignPlatform {
  META
  TIKTOK
  GOOGLE
  ORGANIC
  DIRECT
  PARTNER
  EMAIL
  OTHER
}

enum CampaignSourceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  ARCHIVED
}

enum MediaAssetType {
  IMAGE
  VIDEO
  POSTER
  DOCUMENT
}

enum NormalizedNeedType {
  back
  neck
  stress
  fatigue
  travel
  mobility
  recovery
  other
}

// ─────────────────────────────────────────────────────────────────────────────
// AdminUser — authentification admin
// ─────────────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model AdminSetting {
  key       String   @id
  value     String   @db.Text
  encrypted Boolean  @default(false)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// LeadSubmission — demandes privées reçues depuis la landing page
// ─────────────────────────────────────────────────────────────────────────────

model LeadSubmission {
  id        String  @id @default(cuid())
  firstName String
  contact   String
  type      String
  context   String? @db.Text
  locale    Locale  @default(FR)

  // Qualification B2B / hospitality
  companyName  String?
  jobTitle     String?
  propertyType String?
  destination  String?
  leadSegment  String?

  // Qualification conditionnelle additionnelle
  intent           String?
  preferredChannel String?
  routedToUrl      String?
  urgency          String?
  needType         String?
  volumePotential  String?
  participantCount String?
  currentLocation  String?

  selectedDayLabel String?
  selectedTime     String?
  selectedAt       DateTime?
  timezone         String?
  pageUrl          String?

  utm        Json     @default("{}")
  branchData Json     @default("{}")
  tags       String[] @default([])

  status       LeadStatus @default(CAPTURED)
  ghlContactId String?
  errorMessage String?    @db.Text

  resendEmailId      String?
  notificationSentAt DateTime?
  notificationError  String?   @db.Text

  // Growth CMS attribution
  eventId        String?
  landingPageId  String?
  landingPage    LandingPage?  @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  destinationId  String?
  growthDestination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  offerId        String?
  growthOffer    Offer?        @relation(fields: [offerId], references: [id], onDelete: SetNull)
  source         String?
  medium         String?
  campaign       String?
  content        String?
  creativeAngle  String?
  ctaLocation    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([locale, createdAt])
  @@index([leadSegment])
  @@index([selectedAt])
  @@index([landingPageId])
  @@index([destinationId])
  @@index([offerId])
  @@index([eventId])
  @@map("lead_submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MediaAsset — images et fichiers uploadés localement
// ─────────────────────────────────────────────────────────────────────────────

model MediaAsset {
  id           String @id @default(cuid())
  filename     String @unique // UUID + extension ex: a1b2c3.webp
  originalName String // Nom original du fichier uploadé
  mimeType     String // image/webp, image/jpeg …
  url          String // URL publique ex: /api/uploads/a1b2c3.webp
  localPath    String // Chemin absolu ex: /app/storage/uploads/a1b2c3.webp
  width        Int?
  height       Int?
  size         Int // Taille en octets

  // Textes alt multilingues
  altFr String?
  altEn String?
  altEs String?

  assetType    MediaAssetType @default(IMAGE)
  externalUrl  String?
  consentNotes String?        @db.Text
  usageNotes   String?        @db.Text

  destinationId String?
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Relations inverses
  articles        Article[]             @relation("ArticleCover")
  articlesSeo     ArticleSeo[]          @relation("ArticleOgImage")
  articleVariants ArticleImageVariant[]
  landingSections LandingSection[]      @relation("SectionImage")
  landingHeroImages    LandingPage[]    @relation("LandingHeroImage")
  landingOgImages      LandingPage[]    @relation("LandingOgImage")
  testimonialMedia     Testimonial[]    @relation("TestimonialMedia")
  testimonialPosters   Testimonial[]    @relation("TestimonialPoster")

  @@index([destinationId])
  @@index([assetType])
  @@map("media_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// Article — article de blog multilingue
// ─────────────────────────────────────────────────────────────────────────────

model Article {
  id                 String        @id @default(cuid())
  locale             Locale        @default(FR)
  translationGroupId String?
  slug               String
  title              String
  excerpt            String?
  status             ArticleStatus @default(DRAFT)

  // Image de couverture
  coverImageId String?
  coverImage   MediaAsset? @relation("ArticleCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  authorEntityId String?
  authorEntity   SeoEntity? @relation(fields: [authorEntityId], references: [id], onDelete: SetNull)

  // Relations 1-1
  content ArticleContent?
  seo     ArticleSeo?

  // Relations 1-N
  metrics         ArticleMetric[]
  pageSpeedAudits ArticlePageSpeedAudit[]
  urlInspections  ArticleUrlInspection[]
  transcreations  ArticleTranscreation[]
  audioAssets     ArticleAudioAsset[]
  studioRuns      ArticleStudioRun[]
  studioArtifacts ArticleStudioArtifact[]
  sources         ArticleSource[]
  claims          ArticleClaim[]
  humanEvidence   ArticleHumanEvidence[]
  revisions       ArticleRevision[]
  linkSuggestions SeoLinkSuggestion[]
  imageVariants   ArticleImageVariant[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Un slug est unique par locale
  @@unique([locale, slug])
  @@index([status])
  @@index([locale, status])
  @@index([translationGroupId])
  @@index([authorEntityId])
  @@index([publishedAt])
  @@map("articles")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleContent — corps de l'article (JSON éditeur + HTML + texte)
// ─────────────────────────────────────────────────────────────────────────────

model ArticleContent {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  editorJson  Json? // Document ProseMirror/Tiptap brut
  html        String? // HTML rendu (cache serveur)
  plainText   String? // Texte brut pour recherche / preview
  wordCount   Int     @default(0)
  readingTime Int     @default(0) // En minutes

  @@map("article_contents")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleSeo — métadonnées SEO de l'article
// ─────────────────────────────────────────────────────────────────────────────

model ArticleSeo {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  focusKeyword    String?
  seoTitle        String?
  metaDescription String?
  canonical       String?

  // Open Graph
  ogTitle       String?
  ogDescription String?
  ogImageId     String?
  ogImage       MediaAsset? @relation("ArticleOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)

  noindex Boolean @default(false)

  // Score calculé (0-100) et liste d'issues JSON
  score  Int  @default(0)
  issues Json @default("[]")

  // Score AEO/GEO calculé depuis le contenu visible
  llmReadabilityScore Int       @default(0)
  atomicAnswerPresent Boolean   @default(false)
  schemaValidation    Json      @default("{}")
  geoChecklist        Json      @default("[]")
  answerCoverageScore Int       @default(0)
  lastGeoAuditAt      DateTime?

  // Brief éditorial AEO/GEO et signaux de crédibilité visibles
  primaryQuestion String?
  answerIntent    String?
  targetAudience  String?
  geoLocation     String?
  businessGoal    String?
  entityTargets   Json    @default("[]")
  faqItems        Json    @default("[]")
  evidenceNotes   Json    @default("{}")
  customJsonLd    Json    @default("[]")
  schemaConfig    Json    @default("{}")

  // Scores spécialisés calculés depuis le contenu visible
  aeoScore  Int @default(0)
  geoScore  Int @default(0)
  eeatScore Int @default(0)

  @@map("article_seo")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleTranscreation — versions transcréées et contrôlées par langue
// ─────────────────────────────────────────────────────────────────────────────

model ArticleTranscreation {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  sourceLocale Locale
  targetLocale Locale
  provider     String  @default("GOOGLE_AI_PRO")
  model        String?

  title      String?
  excerpt    String? @db.Text
  editorJson Json?
  html       String? @db.Text
  plainText  String? @db.Text

  promptVersion String?
  reviewStatus  TranscreationStatus @default(AI_GENERATED)
  reviewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId])
  @@index([targetLocale, reviewStatus])
  @@map("article_transcreations")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleAudioAsset — pistes audio multilingues générées ou validées
// ─────────────────────────────────────────────────────────────────────────────

model ArticleAudioAsset {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  locale          Locale
  provider        AudioProvider       @default(ELEVENLABS)
  providerVoiceId String?
  voiceName       String?
  audioUrl        String
  durationSeconds Int?
  transcript      String?             @db.Text
  status          TranscreationStatus @default(AI_GENERATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId])
  @@index([locale, status])
  @@map("article_audio_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleMetric — métriques journalières (Search Console + GA4)
// ─────────────────────────────────────────────────────────────────────────────

model ArticleMetric {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  // Search Console
  clicks      Int   @default(0)
  impressions Int   @default(0)
  ctr         Float @default(0) // 0.0 → 1.0
  position    Float @default(0)

  // GA4
  organicSessions Int @default(0)
  storyViews      Int @default(0)
  ctaClicks       Int @default(0)
  leads           Int @default(0)

  // Un seul enregistrement par article par jour
  @@unique([articleId, date])
  @@index([articleId])
  @@index([date])
  @@map("article_metrics")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticlePageSpeedAudit — historique des audits PageSpeed par article
// ─────────────────────────────────────────────────────────────────────────────

model ArticlePageSpeedAudit {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  url                String
  strategy           String  @default("mobile")
  performanceScore   Int
  seoScore           Int
  accessibilityScore Int
  lcp                String?
  cls                String?
  raw                Json?

  auditedAt DateTime @default(now())

  @@index([articleId, auditedAt])
  @@index([auditedAt])
  @@map("article_pagespeed_audits")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleUrlInspection — historique des inspections d'URL Google
// ─────────────────────────────────────────────────────────────────────────────

model ArticleUrlInspection {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  url             String
  indexStatus     String?
  verdict         String?
  coverageState   String?
  lastCrawlTime   DateTime?
  userCanonical   String?
  googleCanonical String?
  raw             Json?

  inspectedAt DateTime @default(now())

  @@index([articleId, inspectedAt])
  @@index([inspectedAt])
  @@map("article_url_inspections")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI Article Studio — runs, artefacts, sources, claims and revisions
// ─────────────────────────────────────────────────────────────────────────────

model ArticleStudioRun {
  id               String                  @id @default(cuid())
  articleId        String
  article          Article                 @relation(fields: [articleId], references: [id], onDelete: Cascade)
  stage            StudioStage
  status           StudioRunStatus         @default(QUEUED)
  openaiResponseId String?
  model            String
  reasoningEffort  String?
  promptVersion    String
  input            Json
  output           Json?
  error            String?                 @db.Text
  createdBy        String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  artifacts        ArticleStudioArtifact[]

  @@index([articleId, createdAt])
  @@index([status, createdAt])
  @@map("article_studio_runs")
}

model ArticleStudioArtifact {
  id          String               @id @default(cuid())
  articleId   String
  article     Article              @relation(fields: [articleId], references: [id], onDelete: Cascade)
  runId       String?
  run         ArticleStudioRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  stage       StudioStage
  version     Int
  status      StudioArtifactStatus @default(GENERATED)
  contentHash String?
  data        Json
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  sources     ArticleSource[]
  claims      ArticleClaim[]

  @@unique([articleId, stage, version])
  @@index([articleId, stage, status])
  @@index([runId])
  @@map("article_studio_artifacts")
}

model ArticleSource {
  id            String                 @id @default(cuid())
  articleId     String
  article       Article                @relation(fields: [articleId], references: [id], onDelete: Cascade)
  artifactId    String?
  artifact      ArticleStudioArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  url           String                 @db.Text
  title         String
  publisher     String?
  publishedAt   DateTime?
  accessedAt    DateTime               @default(now())
  sourceType    String?
  authorityTier Int                    @default(3)
  status        StudioSourceStatus     @default(CANDIDATE)
  metadata      Json                   @default("{}")
  claimSources  ArticleClaimSource[]

  @@unique([articleId, url])
  @@index([articleId, status])
  @@index([artifactId])
  @@map("article_sources")
}

model ArticleClaim {
  id           String                 @id @default(cuid())
  articleId    String
  article      Article                @relation(fields: [articleId], references: [id], onDelete: Cascade)
  artifactId   String?
  artifact     ArticleStudioArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  text         String                 @db.Text
  riskLevel    String                 @default("NORMAL")
  status       StudioClaimStatus      @default(UNSUPPORTED)
  contentHash  String?
  notes        String?                @db.Text
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  claimSources ArticleClaimSource[]

  @@index([articleId, status])
  @@index([artifactId])
  @@map("article_claims")
}

model ArticleClaimSource {
  claimId  String
  claim    ArticleClaim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sourceId String
  source   ArticleSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([claimId, sourceId])
  @@index([sourceId])
  @@map("article_claim_sources")
}

model ArticleHumanEvidence {
  id         String              @id @default(cuid())
  articleId  String
  article    Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type       String
  text       String              @db.Text
  status     HumanEvidenceStatus @default(DRAFT)
  verifiedBy String?
  verifiedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([articleId, status])
  @@map("article_human_evidence")
}

model ArticleRevision {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  snapshot    Json
  contentHash String
  reason      String
  createdBy   String?
  createdAt   DateTime @default(now())

  @@unique([articleId, contentHash])
  @@index([articleId, createdAt])
  @@map("article_revisions")
}

// ─────────────────────────────────────────────────────────────────────────────
// SEO Intelligence — crawl, graph, redirects, backlinks and entities
// ─────────────────────────────────────────────────────────────────────────────

model SeoCrawlRun {
  id           String          @id @default(cuid())
  status       StudioRunStatus @default(QUEUED)
  baseUrl      String
  totalPages   Int             @default(0)
  crawledPages Int             @default(0)
  error        String?         @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdBy    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  pages        SeoPage[]
  links        SeoLinkEdge[]
  issues       SeoIssue[]

  @@index([status, createdAt])
  @@map("seo_crawl_runs")
}

model SeoPage {
  id                String              @id @default(cuid())
  crawlRunId        String?
  crawlRun          SeoCrawlRun?        @relation(fields: [crawlRunId], references: [id], onDelete: SetNull)
  url               String              @unique @db.Text
  path              String
  locale            Locale?
  pageType          String?
  title             String?
  statusCode        Int
  indexable         Boolean             @default(true)
  canonical         String?             @db.Text
  noindex           Boolean             @default(false)
  contentHash       String?
  plainText         String?             @db.Text
  depth             Int?
  lastCrawledAt     DateTime            @default(now())
  outgoingLinks     SeoLinkEdge[]       @relation("SeoLinkSource")
  incomingLinks     SeoLinkEdge[]       @relation("SeoLinkTarget")
  issues            SeoIssue[]
  sourceSuggestions SeoLinkSuggestion[] @relation("SuggestionSource")
  targetSuggestions SeoLinkSuggestion[] @relation("SuggestionTarget")

  @@index([locale, pageType])
  @@index([indexable, statusCode])
  @@index([crawlRunId])
  @@map("seo_pages")
}

model SeoLinkEdge {
  id             String      @id @default(cuid())
  crawlRunId     String
  crawlRun       SeoCrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  sourcePageId   String
  sourcePage     SeoPage     @relation("SeoLinkSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPageId   String?
  targetPage     SeoPage?    @relation("SeoLinkTarget", fields: [targetPageId], references: [id], onDelete: SetNull)
  targetUrl      String      @db.Text
  anchor         String?
  rel            String?
  statusCode     Int?
  internal       Boolean     @default(true)
  localeMismatch Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@index([crawlRunId, sourcePageId])
  @@index([targetPageId])
  @@map("seo_link_edges")
}

model SeoIssue {
  id         String           @id @default(cuid())
  crawlRunId String
  crawlRun   SeoCrawlRun      @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  pageId     String?
  page       SeoPage?         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type       String
  severity   SeoIssueSeverity
  message    String           @db.Text
  data       Json             @default("{}")
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([crawlRunId, severity])
  @@index([pageId])
  @@map("seo_issues")
}

model SeoLinkSuggestion {
  id           String              @id @default(cuid())
  articleId    String?
  article      Article?            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sourcePageId String
  sourcePage   SeoPage             @relation("SuggestionSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPageId String
  targetPage   SeoPage             @relation("SuggestionTarget", fields: [targetPageId], references: [id], onDelete: Cascade)
  anchor       String
  context      String?             @db.Text
  reason       String              @db.Text
  confidence   Float
  status       SeoSuggestionStatus @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([articleId, status])
  @@index([sourcePageId, targetPageId])
  @@map("seo_link_suggestions")
}

model SeoRedirect {
  id              String    @id @default(cuid())
  sourcePath      String    @unique
  destinationPath String
  statusCode      Int       @default(301)
  active          Boolean   @default(true)
  hits            Int       @default(0)
  lastHitAt       DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, sourcePath])
  @@map("seo_redirects")
}

model BacklinkImport {
  id            String          @id @default(cuid())
  fileName      String
  provider      String          @default("AHREFS_CSV")
  status        StudioRunStatus @default(QUEUED)
  rowCount      Int             @default(0)
  importedCount Int             @default(0)
  mapping       Json            @default("{}")
  error         String?         @db.Text
  createdBy     String?
  createdAt     DateTime        @default(now())
  completedAt   DateTime?
  backlinks     Backlink[]

  @@index([status, createdAt])
  @@map("backlink_imports")
}

model Backlink {
  id           String         @id @default(cuid())
  importId     String
  import       BacklinkImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  sourceUrl    String         @db.Text
  sourceDomain String
  targetUrl    String         @db.Text
  anchor       String?
  rel          String?
  firstSeen    DateTime?
  lastSeen     DateTime?
  status       String         @default("ACTIVE")
  metrics      Json           @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([sourceDomain])
  @@index([status, lastSeen])
  @@index([importId])
  @@map("backlinks")
}

model SeoEntity {
  id          String        @id @default(cuid())
  type        SeoEntityType
  name        String
  slug        String        @unique
  url         String?
  description String?       @db.Text
  imageUrl    String?
  sameAs      Json          @default("[]")
  credentials Json          @default("[]")
  metadata    Json          @default("{}")
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  articles    Article[]

  @@index([type, active])
  @@map("seo_entities")
}

model ArticleImageVariant {
  id        String     @id @default(cuid())
  articleId String
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assetId   String
  asset     MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ratio     String
  kind      String     @default("COVER")
  createdAt DateTime   @default(now())

  @@unique([articleId, ratio, kind])
  @@index([assetId])
  @@map("article_image_variants")
}

// ─────────────────────────────────────────────────────────────────────────────
// LandingSection — blocs dynamiques de la landing page
// ─────────────────────────────────────────────────────────────────────────────

model LandingSection {
  id        String               @id @default(cuid())
  type      String // "hero" | "about" | "testimonial" | "cta" …
  locale    Locale               @default(FR)
  status    LandingSectionStatus @default(DRAFT)
  placement Int                  @default(0) // Ordre d'affichage

  // Contenu éditorial
  title    String?
  subtitle String?
  body     String?
  ctaLabel String?
  ctaHref  String?

  // Image associée
  imageId String?
  image   MediaAsset? @relation("SectionImage", fields: [imageId], references: [id], onDelete: SetNull)

  // Planification
  startAt DateTime?
  endAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, status])
  @@index([type, locale])
  @@map("landing_sections")
}

// ─────────────────────────────────────────────────────────────────────────────
// Growth CMS — destinations, landings, offers, tracking, CRM
// ─────────────────────────────────────────────────────────────────────────────

model Destination {
  id          String              @id @default(cuid())
  slug        String              @unique
  cityName    String
  displayNameFr String
  displayNameEn String
  displayNameEs String
  country     String
  region      String?
  timezone    String              @default("UTC")
  currency    String              @default("USD")
  locales     Locale[]            @default([FR, EN, ES])
  neighborhoods Json              @default("[]")
  targetSegments Json             @default("[]")
  status      DestinationStatus   @default(DRAFT)
  maturity    DestinationMaturity @default(TEST)
  startAt     DateTime?
  endAt       DateTime?
  defaultWhatsappChannelId String? @unique
  defaultTrackingProfileId String? @unique
  defaultOfferId           String? @unique
  internalNotes String?         @db.Text
  publicNotes   String?         @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  defaultWhatsappChannel WhatsappChannel? @relation("DestinationDefaultWhatsapp", fields: [defaultWhatsappChannelId], references: [id], onDelete: SetNull)
  defaultTrackingProfile TrackingProfile? @relation("DestinationDefaultTracking", fields: [defaultTrackingProfileId], references: [id], onDelete: SetNull)
  defaultOffer           Offer?           @relation("DestinationDefaultOffer", fields: [defaultOfferId], references: [id], onDelete: SetNull)

  offers            Offer[]            @relation("DestinationOffers")
  landingPages      LandingPage[]
  whatsappChannels  WhatsappChannel[]  @relation("DestinationWhatsappChannels")
  trackingProfiles  TrackingProfile[]
  testimonials      Testimonial[]
  crmRoutingRules   CrmRoutingRule[]
  campaignSources   CampaignSource[]
  mediaAssets       MediaAsset[]
  leadSubmissions   LeadSubmission[]
  pixelEventLogs    PixelEventLog[]

  @@index([status])
  @@index([country])
  @@map("destinations")
}

model Offer {
  id              String      @id @default(cuid())
  destinationId   String
  destination     Destination @relation("DestinationOffers", fields: [destinationId], references: [id], onDelete: Cascade)
  type            OfferType
  internalName    String
  publicNameFr      String
  publicNameEn      String
  publicNameEs      String
  shortDescriptionFr String?  @db.Text
  shortDescriptionEn String?  @db.Text
  shortDescriptionEs String?  @db.Text
  durationMinutes   Int?
  priceAmount       Decimal?  @db.Decimal(10, 2)
  currency          String?
  showPrice         Boolean   @default(false)
  priceNoteFr       String?
  priceNoteEn       String?
  priceNoteEs       String?
  bookingUrl        String?
  paymentUrl        String?
  primaryCtaFr      String?
  primaryCtaEn      String?
  primaryCtaEs      String?
  secondaryCtaFr    String?
  secondaryCtaEn    String?
  secondaryCtaEs    String?
  conditionsFr      String?   @db.Text
  conditionsEn      String?   @db.Text
  conditionsEs      String?   @db.Text
  status            OfferStatus @default(DRAFT)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  landingPages    LandingPage[]
  testimonials    Testimonial[]
  campaignSources CampaignSource[]
  leadSubmissions LeadSubmission[]
  defaultForDestination Destination? @relation("DestinationDefaultOffer")

  @@index([destinationId, status])
  @@index([type])
  @@map("offers")
}

model WhatsappChannel {
  id                      String                @id @default(cuid())
  destinationId           String
  destination             Destination           @relation("DestinationWhatsappChannels", fields: [destinationId], references: [id], onDelete: Cascade)
  label                   String
  phoneE164               String
  provider                WhatsappProvider      @default(WHATSAPP_APP)
  status                  WhatsappChannelStatus @default(NOT_CONFIGURED)
  defaultLocale           Locale                @default(FR)
  prefilledMessageFr       String                @db.Text
  prefilledMessageEn       String                @db.Text
  prefilledMessageEs       String                @db.Text
  ghlWorkflowHotLeadId    String?
  ghlWorkflowInfoNeededId String?
  ghlWorkflowBookingId    String?
  fallbackUrl             String?
  ownerName               String?
  businessHours           Json                  @default("{}")
  lastVerifiedAt          DateTime?
  notes                   String?               @db.Text
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  landingPages      LandingPage[]
  defaultForDestination Destination? @relation("DestinationDefaultWhatsapp")

  @@index([destinationId, status])
  @@map("whatsapp_channels")
}

model TrackingProfile {
  id                 String                @id @default(cuid())
  destinationId      String
  destination        Destination           @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  label              String
  metaPixelId        String?
  tiktokPixelId      String?
  ga4MeasurementId   String?
  googleAdsId        String?
  gtmContainerId     String?
  consentMode        String                @default("basic")
  enableMeta         Boolean               @default(true)
  enableTikTok       Boolean               @default(false)
  enableGA4          Boolean               @default(true)
  enableGTM          Boolean               @default(false)
  enableGoogleAds    Boolean               @default(false)
  status             TrackingProfileStatus @default(DRAFT)
  notes              String?               @db.Text
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  landingPages      LandingPage[]
  defaultForDestination Destination? @relation("DestinationDefaultTracking")

  @@index([destinationId, status])
  @@map("tracking_profiles")
}

model CrmRoutingRule {
  id                  String           @id @default(cuid())
  destinationId       String
  destination         Destination      @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  locale              Locale?
  offerType           OfferType?
  source              String?
  intent              String?
  leadSegment         String?
  ghlPipelineId       String?
  ghlPipelineStageId  String?
  ghlWorkflowId       String?
  ghlAssignedUserId   String?
  tags                Json             @default("[]")
  customFields        Json             @default("{}")
  priority            Int              @default(100)
  status              CrmRoutingStatus @default(DRAFT)
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  landingPages LandingPage[]

  @@index([destinationId, status, priority])
  @@map("crm_routing_rules")
}

model LandingPage {
  id                String          @id @default(cuid())
  destinationId     String
  destination       Destination     @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  offerId           String?
  offer             Offer?          @relation(fields: [offerId], references: [id], onDelete: SetNull)
  locale            Locale
  template          LandingTemplate @default(MOBILE_WHATSAPP_FIRST)
  slug              String
  status            LandingStatus   @default(DRAFT)
  heroTitle         String
  heroSubtitle      String?         @db.Text
  microNote         String?
  primaryCta        String?
  secondaryCta      String?
  painChips         Json            @default("[]")
  proofBadges       Json            @default("[]")
  processSteps      Json            @default("[]")
  faq               Json            @default("[]")
  content           Json            @default("{}")
  complianceText    String?         @db.Text
  heroImageId       String?
  heroImage         MediaAsset?     @relation("LandingHeroImage", fields: [heroImageId], references: [id], onDelete: SetNull)
  ogImageId         String?
  ogImage           MediaAsset?     @relation("LandingOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)
  testimonialIds    Json            @default("[]")
  whatsappChannelId String?
  whatsappChannel   WhatsappChannel? @relation(fields: [whatsappChannelId], references: [id], onDelete: SetNull)
  trackingProfileId String?
  trackingProfile   TrackingProfile? @relation(fields: [trackingProfileId], references: [id], onDelete: SetNull)
  crmRoutingRuleId  String?
  crmRoutingRule    CrmRoutingRule?  @relation(fields: [crmRoutingRuleId], references: [id], onDelete: SetNull)
  seoTitle          String?
  metaDescription   String?         @db.Text
  canonical         String?
  noindex           Boolean         @default(true)
  hreflangGroupId   String?
  xDefault          Boolean         @default(false)
  areaServed        String?
  schemaConfig      Json            @default("{}")
  readinessScore    Int             @default(0)
  readinessIssues   Json            @default("[]")
  previewToken      String?         @unique @default(cuid())
  publishedAt       DateTime?
  publishOverride   Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  leadSubmissions   LeadSubmission[]
  pixelEventLogs    PixelEventLog[]
  campaignSources   CampaignSource[]
  experiments       Experiment[]
  dailyMetrics      LandingMetricDaily[]

  @@unique([locale, slug])
  @@index([destinationId, locale, status])
  @@index([hreflangGroupId])
  @@index([status, noindex])
  @@map("landing_pages")
}

model PixelEventLog {
  id              String              @id @default(cuid())
  eventId         String
  eventName       String
  landingPageId   String?
  landingPage     LandingPage?        @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  destinationId   String?
  destination     Destination?        @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  locale          Locale?
  offerId         String?
  source          String?
  medium          String?
  campaign        String?
  content         String?
  creativeAngle   String?
  ctaLocation     String?
  needType        NormalizedNeedType?
  pageUrl         String?
  sessionId       String?
  sentToMeta      Boolean             @default(false)
  sentToTikTok    Boolean             @default(false)
  sentToGA4       Boolean             @default(false)
  sentToGTM       Boolean             @default(false)
  errors          Json                @default("[]")
  createdAt       DateTime            @default(now())

  @@index([eventName, createdAt])
  @@index([landingPageId, createdAt])
  @@index([destinationId, createdAt])
  @@index([eventId])
  @@map("pixel_event_logs")
}

model Testimonial {
  id              String            @id @default(cuid())
  firstName       String?
  displayName     String
  locale          Locale
  country         String?
  city            String?
  profile         String?
  ageRange        String?
  occupation      String?
  destinationId   String?
  destination     Destination?      @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  offerId         String?
  offer           Offer?            @relation(fields: [offerId], references: [id], onDelete: SetNull)
  mediaAssetId    String?
  mediaAsset      MediaAsset?       @relation("TestimonialMedia", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  posterImageId   String?
  posterImage     MediaAsset?       @relation("TestimonialPoster", fields: [posterImageId], references: [id], onDelete: SetNull)
  transcript      String?           @db.Text
  subtitlesUrl    String?
  quoteShort      String?
  quoteLong       String?           @db.Text
  consentWebsite  Boolean           @default(false)
  consentAds      Boolean           @default(false)
  consentOrganic  Boolean           @default(true)
  emotionalScore  Int               @default(0)
  credibilityScore Int              @default(0)
  priority        Int               @default(0)
  status          TestimonialStatus @default(DRAFT)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  experimentVariants ExperimentVariant[]

  @@index([destinationId, locale, status])
  @@index([priority])
  @@map("testimonials")
}

model CampaignSource {
  id              String               @id @default(cuid())
  name            String
  source          String
  medium          String
  platform        CampaignPlatform
  destinationId   String?
  destination     Destination?         @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  landingPageId   String?
  landingPage     LandingPage?         @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  offerId         String?
  offer           Offer?               @relation(fields: [offerId], references: [id], onDelete: SetNull)
  locale          Locale?
  campaignName    String?
  adsetName       String?
  adName          String?
  creativeAngle   String?
  utmTemplate     String?
  status          CampaignSourceStatus @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([destinationId, platform])
  @@index([landingPageId])
  @@map("campaign_sources")
}

model Experiment {
  id              String           @id @default(cuid())
  landingPageId   String
  landingPage     LandingPage      @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  name            String
  hypothesis      String?          @db.Text
  status          ExperimentStatus @default(DRAFT)
  startAt         DateTime?
  endAt           DateTime?
  primaryMetric   String           @default("whatsapp_clicks")
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  variants ExperimentVariant[]

  @@index([landingPageId, status])
  @@map("experiments")
}

model ExperimentVariant {
  id               String       @id @default(cuid())
  experimentId     String
  experiment       Experiment   @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  name             String
  trafficSplit     Int          @default(50)
  heroTitle        String?
  heroSubtitle     String?      @db.Text
  primaryCta       String?
  testimonialId    String?
  testimonial      Testimonial? @relation(fields: [testimonialId], references: [id], onDelete: SetNull)
  contentOverrides Json         @default("{}")
  impressions      Int          @default(0)
  whatsappClicks   Int          @default(0)
  formSubmits      Int          @default(0)
  bookingClicks    Int          @default(0)
  leads            Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([experimentId])
  @@map("experiment_variants")
}

model RedirectRule {
  id          String   @id @default(cuid())
  sourcePath  String   @unique
  targetPath  String
  statusCode  Int      @default(301)
  active      Boolean  @default(true)
  reason      String?
  hits        Int      @default(0)
  lastHitAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@map("redirect_rules")
}

model LandingMetricDaily {
  id              String      @id @default(cuid())
  landingPageId   String
  landingPage     LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  date            DateTime    @db.Date
  views           Int         @default(0)
  whatsappClicks  Int         @default(0)
  stickyClicks    Int         @default(0)
  formStarts      Int         @default(0)
  formSubmits     Int         @default(0)
  bookingClicks   Int         @default(0)
  paymentClicks   Int         @default(0)
  videoPlays      Int         @default(0)
  leads           Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([landingPageId, date])
  @@index([date])
  @@map("landing_metric_daily")
}
