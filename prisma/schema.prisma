// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Méthode TMS® CMS
// Prisma 7 : pas de `url` dans datasource (géré via prisma.config.ts)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Locale {
  FR
  EN
  ES
}

enum ArticleStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum LandingSectionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadStatus {
  CAPTURED
  MOCKED
  SENT_TO_GHL
  FAILED
  ARCHIVED
}

enum TranscreationStatus {
  DRAFT
  AI_GENERATED
  REVIEWED
  PUBLISHED
  ARCHIVED
}

enum AudioProvider {
  ELEVENLABS
  OTHER
}

enum StudioStage {
  RESEARCH
  BRIEF
  OUTLINE
  DRAFT
  FACT_CHECK
  SEO
  TRANSLATION
  IMAGE
}

enum StudioRunStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum StudioArtifactStatus {
  GENERATED
  APPROVED
  REJECTED
  SUPERSEDED
}

enum StudioClaimStatus {
  VERIFIED
  NEEDS_NUANCE
  UNSUPPORTED
  HUMAN_EVIDENCE_REQUIRED
}

enum StudioSourceStatus {
  CANDIDATE
  APPROVED
  REJECTED
}

enum HumanEvidenceStatus {
  DRAFT
  VERIFIED
  REJECTED
}

enum SeoIssueSeverity {
  INFO
  WARNING
  CRITICAL
}

enum SeoSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  APPLIED
}

enum SeoEntityType {
  PERSON
  ORGANIZATION
  LOCAL_BUSINESS
}

// ─────────────────────────────────────────────────────────────────────────────
// AdminUser — authentification admin
// ─────────────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model AdminSetting {
  key       String   @id
  value     String   @db.Text
  encrypted Boolean  @default(false)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// LeadSubmission — demandes privées reçues depuis la landing page
// ─────────────────────────────────────────────────────────────────────────────

model LeadSubmission {
  id        String  @id @default(cuid())
  firstName String
  contact   String
  type      String
  context   String? @db.Text
  locale    Locale  @default(FR)

  // Qualification B2B / hospitality
  companyName  String?
  jobTitle     String?
  propertyType String?
  destination  String?
  leadSegment  String?

  // Qualification conditionnelle additionnelle
  intent           String?
  preferredChannel String?
  routedToUrl      String?
  urgency          String?
  needType         String?
  volumePotential  String?
  participantCount String?
  currentLocation  String?

  selectedDayLabel String?
  selectedTime     String?
  selectedAt       DateTime?
  timezone         String?
  pageUrl          String?

  utm        Json     @default("{}")
  branchData Json     @default("{}")
  tags       String[] @default([])

  status       LeadStatus @default(CAPTURED)
  ghlContactId String?
  errorMessage String?    @db.Text

  resendEmailId      String?
  notificationSentAt DateTime?
  notificationError  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([locale, createdAt])
  @@index([leadSegment])
  @@index([selectedAt])
  @@map("lead_submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MediaAsset — images et fichiers uploadés localement
// ─────────────────────────────────────────────────────────────────────────────

model MediaAsset {
  id           String @id @default(cuid())
  filename     String @unique // UUID + extension ex: a1b2c3.webp
  originalName String // Nom original du fichier uploadé
  mimeType     String // image/webp, image/jpeg …
  url          String // URL publique ex: /api/uploads/a1b2c3.webp
  localPath    String // Chemin absolu ex: /app/storage/uploads/a1b2c3.webp
  width        Int?
  height       Int?
  size         Int // Taille en octets

  // Textes alt multilingues
  altFr String?
  altEn String?
  altEs String?

  createdAt DateTime @default(now())

  // Relations inverses
  articles        Article[]             @relation("ArticleCover")
  articlesSeo     ArticleSeo[]          @relation("ArticleOgImage")
  articleVariants ArticleImageVariant[]
  landingSections LandingSection[]      @relation("SectionImage")

  @@map("media_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// Article — article de blog multilingue
// ─────────────────────────────────────────────────────────────────────────────

model Article {
  id                 String        @id @default(cuid())
  locale             Locale        @default(FR)
  translationGroupId String?
  slug               String
  title              String
  excerpt            String?
  status             ArticleStatus @default(DRAFT)

  // Image de couverture
  coverImageId String?
  coverImage   MediaAsset? @relation("ArticleCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  authorEntityId String?
  authorEntity   SeoEntity? @relation(fields: [authorEntityId], references: [id], onDelete: SetNull)

  // Relations 1-1
  content ArticleContent?
  seo     ArticleSeo?

  // Relations 1-N
  metrics         ArticleMetric[]
  pageSpeedAudits ArticlePageSpeedAudit[]
  urlInspections  ArticleUrlInspection[]
  transcreations  ArticleTranscreation[]
  audioAssets     ArticleAudioAsset[]
  studioRuns      ArticleStudioRun[]
  studioArtifacts ArticleStudioArtifact[]
  sources         ArticleSource[]
  claims          ArticleClaim[]
  humanEvidence   ArticleHumanEvidence[]
  revisions       ArticleRevision[]
  linkSuggestions SeoLinkSuggestion[]
  imageVariants   ArticleImageVariant[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Un slug est unique par locale
  @@unique([locale, slug])
  @@index([status])
  @@index([locale, status])
  @@index([translationGroupId])
  @@index([authorEntityId])
  @@index([publishedAt])
  @@map("articles")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleContent — corps de l'article (JSON éditeur + HTML + texte)
// ─────────────────────────────────────────────────────────────────────────────

model ArticleContent {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  editorJson  Json? // Document ProseMirror/Tiptap brut
  html        String? // HTML rendu (cache serveur)
  plainText   String? // Texte brut pour recherche / preview
  wordCount   Int     @default(0)
  readingTime Int     @default(0) // En minutes

  @@map("article_contents")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleSeo — métadonnées SEO de l'article
// ─────────────────────────────────────────────────────────────────────────────

model ArticleSeo {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  focusKeyword    String?
  seoTitle        String?
  metaDescription String?
  canonical       String?

  // Open Graph
  ogTitle       String?
  ogDescription String?
  ogImageId     String?
  ogImage       MediaAsset? @relation("ArticleOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)

  noindex Boolean @default(false)

  // Score calculé (0-100) et liste d'issues JSON
  score  Int  @default(0)
  issues Json @default("[]")

  // Score AEO/GEO calculé depuis le contenu visible
  llmReadabilityScore Int       @default(0)
  atomicAnswerPresent Boolean   @default(false)
  schemaValidation    Json      @default("{}")
  geoChecklist        Json      @default("[]")
  answerCoverageScore Int       @default(0)
  lastGeoAuditAt      DateTime?

  // Brief éditorial AEO/GEO et signaux de crédibilité visibles
  primaryQuestion String?
  answerIntent    String?
  targetAudience  String?
  geoLocation     String?
  businessGoal    String?
  entityTargets   Json    @default("[]")
  faqItems        Json    @default("[]")
  evidenceNotes   Json    @default("{}")
  customJsonLd    Json    @default("[]")
  schemaConfig    Json    @default("{}")

  // Scores spécialisés calculés depuis le contenu visible
  aeoScore  Int @default(0)
  geoScore  Int @default(0)
  eeatScore Int @default(0)

  @@map("article_seo")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleTranscreation — versions transcréées et contrôlées par langue
// ─────────────────────────────────────────────────────────────────────────────

model ArticleTranscreation {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  sourceLocale Locale
  targetLocale Locale
  provider     String  @default("GOOGLE_AI_PRO")
  model        String?

  title      String?
  excerpt    String? @db.Text
  editorJson Json?
  html       String? @db.Text
  plainText  String? @db.Text

  promptVersion String?
  reviewStatus  TranscreationStatus @default(AI_GENERATED)
  reviewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId])
  @@index([targetLocale, reviewStatus])
  @@map("article_transcreations")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleAudioAsset — pistes audio multilingues générées ou validées
// ─────────────────────────────────────────────────────────────────────────────

model ArticleAudioAsset {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  locale          Locale
  provider        AudioProvider       @default(ELEVENLABS)
  providerVoiceId String?
  voiceName       String?
  audioUrl        String
  durationSeconds Int?
  transcript      String?             @db.Text
  status          TranscreationStatus @default(AI_GENERATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId])
  @@index([locale, status])
  @@map("article_audio_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleMetric — métriques journalières (Search Console + GA4)
// ─────────────────────────────────────────────────────────────────────────────

model ArticleMetric {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  // Search Console
  clicks      Int   @default(0)
  impressions Int   @default(0)
  ctr         Float @default(0) // 0.0 → 1.0
  position    Float @default(0)

  // GA4
  organicSessions Int @default(0)
  storyViews      Int @default(0)
  ctaClicks       Int @default(0)
  leads           Int @default(0)

  // Un seul enregistrement par article par jour
  @@unique([articleId, date])
  @@index([articleId])
  @@index([date])
  @@map("article_metrics")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticlePageSpeedAudit — historique des audits PageSpeed par article
// ─────────────────────────────────────────────────────────────────────────────

model ArticlePageSpeedAudit {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  url                String
  strategy           String  @default("mobile")
  performanceScore   Int
  seoScore           Int
  accessibilityScore Int
  lcp                String?
  cls                String?
  raw                Json?

  auditedAt DateTime @default(now())

  @@index([articleId, auditedAt])
  @@index([auditedAt])
  @@map("article_pagespeed_audits")
}

// ─────────────────────────────────────────────────────────────────────────────
// ArticleUrlInspection — historique des inspections d'URL Google
// ─────────────────────────────────────────────────────────────────────────────

model ArticleUrlInspection {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  url             String
  indexStatus     String?
  verdict         String?
  coverageState   String?
  lastCrawlTime   DateTime?
  userCanonical   String?
  googleCanonical String?
  raw             Json?

  inspectedAt DateTime @default(now())

  @@index([articleId, inspectedAt])
  @@index([inspectedAt])
  @@map("article_url_inspections")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI Article Studio — runs, artefacts, sources, claims and revisions
// ─────────────────────────────────────────────────────────────────────────────

model ArticleStudioRun {
  id               String                  @id @default(cuid())
  articleId        String
  article          Article                 @relation(fields: [articleId], references: [id], onDelete: Cascade)
  stage            StudioStage
  status           StudioRunStatus         @default(QUEUED)
  openaiResponseId String?
  model            String
  reasoningEffort  String?
  promptVersion    String
  input            Json
  output           Json?
  error            String?                 @db.Text
  createdBy        String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  artifacts        ArticleStudioArtifact[]

  @@index([articleId, createdAt])
  @@index([status, createdAt])
  @@map("article_studio_runs")
}

model ArticleStudioArtifact {
  id          String               @id @default(cuid())
  articleId   String
  article     Article              @relation(fields: [articleId], references: [id], onDelete: Cascade)
  runId       String?
  run         ArticleStudioRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  stage       StudioStage
  version     Int
  status      StudioArtifactStatus @default(GENERATED)
  contentHash String?
  data        Json
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  sources     ArticleSource[]
  claims      ArticleClaim[]

  @@unique([articleId, stage, version])
  @@index([articleId, stage, status])
  @@index([runId])
  @@map("article_studio_artifacts")
}

model ArticleSource {
  id            String                 @id @default(cuid())
  articleId     String
  article       Article                @relation(fields: [articleId], references: [id], onDelete: Cascade)
  artifactId    String?
  artifact      ArticleStudioArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  url           String                 @db.Text
  title         String
  publisher     String?
  publishedAt   DateTime?
  accessedAt    DateTime               @default(now())
  sourceType    String?
  authorityTier Int                    @default(3)
  status        StudioSourceStatus     @default(CANDIDATE)
  metadata      Json                   @default("{}")
  claimSources  ArticleClaimSource[]

  @@unique([articleId, url])
  @@index([articleId, status])
  @@index([artifactId])
  @@map("article_sources")
}

model ArticleClaim {
  id           String                 @id @default(cuid())
  articleId    String
  article      Article                @relation(fields: [articleId], references: [id], onDelete: Cascade)
  artifactId   String?
  artifact     ArticleStudioArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  text         String                 @db.Text
  riskLevel    String                 @default("NORMAL")
  status       StudioClaimStatus      @default(UNSUPPORTED)
  contentHash  String?
  notes        String?                @db.Text
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  claimSources ArticleClaimSource[]

  @@index([articleId, status])
  @@index([artifactId])
  @@map("article_claims")
}

model ArticleClaimSource {
  claimId  String
  claim    ArticleClaim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sourceId String
  source   ArticleSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([claimId, sourceId])
  @@index([sourceId])
  @@map("article_claim_sources")
}

model ArticleHumanEvidence {
  id         String              @id @default(cuid())
  articleId  String
  article    Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type       String
  text       String              @db.Text
  status     HumanEvidenceStatus @default(DRAFT)
  verifiedBy String?
  verifiedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([articleId, status])
  @@map("article_human_evidence")
}

model ArticleRevision {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  snapshot    Json
  contentHash String
  reason      String
  createdBy   String?
  createdAt   DateTime @default(now())

  @@unique([articleId, contentHash])
  @@index([articleId, createdAt])
  @@map("article_revisions")
}

// ─────────────────────────────────────────────────────────────────────────────
// SEO Intelligence — crawl, graph, redirects, backlinks and entities
// ─────────────────────────────────────────────────────────────────────────────

model SeoCrawlRun {
  id           String          @id @default(cuid())
  status       StudioRunStatus @default(QUEUED)
  baseUrl      String
  totalPages   Int             @default(0)
  crawledPages Int             @default(0)
  error        String?         @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdBy    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  pages        SeoPage[]
  links        SeoLinkEdge[]
  issues       SeoIssue[]

  @@index([status, createdAt])
  @@map("seo_crawl_runs")
}

model SeoPage {
  id                String              @id @default(cuid())
  crawlRunId        String?
  crawlRun          SeoCrawlRun?        @relation(fields: [crawlRunId], references: [id], onDelete: SetNull)
  url               String              @unique @db.Text
  path              String
  locale            Locale?
  pageType          String?
  title             String?
  statusCode        Int
  indexable         Boolean             @default(true)
  canonical         String?             @db.Text
  noindex           Boolean             @default(false)
  contentHash       String?
  plainText         String?             @db.Text
  depth             Int?
  lastCrawledAt     DateTime            @default(now())
  outgoingLinks     SeoLinkEdge[]       @relation("SeoLinkSource")
  incomingLinks     SeoLinkEdge[]       @relation("SeoLinkTarget")
  issues            SeoIssue[]
  sourceSuggestions SeoLinkSuggestion[] @relation("SuggestionSource")
  targetSuggestions SeoLinkSuggestion[] @relation("SuggestionTarget")

  @@index([locale, pageType])
  @@index([indexable, statusCode])
  @@index([crawlRunId])
  @@map("seo_pages")
}

model SeoLinkEdge {
  id             String      @id @default(cuid())
  crawlRunId     String
  crawlRun       SeoCrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  sourcePageId   String
  sourcePage     SeoPage     @relation("SeoLinkSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPageId   String?
  targetPage     SeoPage?    @relation("SeoLinkTarget", fields: [targetPageId], references: [id], onDelete: SetNull)
  targetUrl      String      @db.Text
  anchor         String?
  rel            String?
  statusCode     Int?
  internal       Boolean     @default(true)
  localeMismatch Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@index([crawlRunId, sourcePageId])
  @@index([targetPageId])
  @@map("seo_link_edges")
}

model SeoIssue {
  id         String           @id @default(cuid())
  crawlRunId String
  crawlRun   SeoCrawlRun      @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  pageId     String?
  page       SeoPage?         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type       String
  severity   SeoIssueSeverity
  message    String           @db.Text
  data       Json             @default("{}")
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([crawlRunId, severity])
  @@index([pageId])
  @@map("seo_issues")
}

model SeoLinkSuggestion {
  id           String              @id @default(cuid())
  articleId    String?
  article      Article?            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sourcePageId String
  sourcePage   SeoPage             @relation("SuggestionSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPageId String
  targetPage   SeoPage             @relation("SuggestionTarget", fields: [targetPageId], references: [id], onDelete: Cascade)
  anchor       String
  context      String?             @db.Text
  reason       String              @db.Text
  confidence   Float
  status       SeoSuggestionStatus @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([articleId, status])
  @@index([sourcePageId, targetPageId])
  @@map("seo_link_suggestions")
}

model SeoRedirect {
  id              String    @id @default(cuid())
  sourcePath      String    @unique
  destinationPath String
  statusCode      Int       @default(301)
  active          Boolean   @default(true)
  hits            Int       @default(0)
  lastHitAt       DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, sourcePath])
  @@map("seo_redirects")
}

model BacklinkImport {
  id            String          @id @default(cuid())
  fileName      String
  provider      String          @default("AHREFS_CSV")
  status        StudioRunStatus @default(QUEUED)
  rowCount      Int             @default(0)
  importedCount Int             @default(0)
  mapping       Json            @default("{}")
  error         String?         @db.Text
  createdBy     String?
  createdAt     DateTime        @default(now())
  completedAt   DateTime?
  backlinks     Backlink[]

  @@index([status, createdAt])
  @@map("backlink_imports")
}

model Backlink {
  id           String         @id @default(cuid())
  importId     String
  import       BacklinkImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  sourceUrl    String         @db.Text
  sourceDomain String
  targetUrl    String         @db.Text
  anchor       String?
  rel          String?
  firstSeen    DateTime?
  lastSeen     DateTime?
  status       String         @default("ACTIVE")
  metrics      Json           @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([sourceDomain])
  @@index([status, lastSeen])
  @@index([importId])
  @@map("backlinks")
}

model SeoEntity {
  id          String        @id @default(cuid())
  type        SeoEntityType
  name        String
  slug        String        @unique
  url         String?
  description String?       @db.Text
  imageUrl    String?
  sameAs      Json          @default("[]")
  credentials Json          @default("[]")
  metadata    Json          @default("{}")
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  articles    Article[]

  @@index([type, active])
  @@map("seo_entities")
}

model ArticleImageVariant {
  id        String     @id @default(cuid())
  articleId String
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assetId   String
  asset     MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ratio     String
  kind      String     @default("COVER")
  createdAt DateTime   @default(now())

  @@unique([articleId, ratio, kind])
  @@index([assetId])
  @@map("article_image_variants")
}

// ─────────────────────────────────────────────────────────────────────────────
// LandingSection — blocs dynamiques de la landing page
// ─────────────────────────────────────────────────────────────────────────────

model LandingSection {
  id        String               @id @default(cuid())
  type      String // "hero" | "about" | "testimonial" | "cta" …
  locale    Locale               @default(FR)
  status    LandingSectionStatus @default(DRAFT)
  placement Int                  @default(0) // Ordre d'affichage

  // Contenu éditorial
  title    String?
  subtitle String?
  body     String?
  ctaLabel String?
  ctaHref  String?

  // Image associée
  imageId String?
  image   MediaAsset? @relation("SectionImage", fields: [imageId], references: [id], onDelete: SetNull)

  // Planification
  startAt DateTime?
  endAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, status])
  @@index([type, locale])
  @@map("landing_sections")
}
